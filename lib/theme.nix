  base01 = "#121212";
  base02 = "#222222";
  base03 = "#333333";
  base04 = "#999999";
  base05 = "#c1c1c1";
  base06 = "#999999";
  base07 = "#c1c1c1";
  base08 = "#5f8787";
  base09 = "#aaaaaa";
  base0A = "#e78a53";
  base0B = "#fbcb97";
  base0C = "#aaaaaa";
  base0D = "#888888";
  base0E = "#999999";
  base0F = "#444444";
}
