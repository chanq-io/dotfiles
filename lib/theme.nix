# Petrol Noir palette (connormxfadden/petrolnoir).
# Consumed by home-manager modules that need colour values (kitty, waybar,
# wofi, mako, hyprlock, neovim, etc.). Kept as pure data so a future runtime
# pipeline (e.g. wallust / matugen) can drop-in replace the source file.
{
  base00 = "#0b0d10";   # bg
  base01 = "#101419";   # lighter bg
  base02 = "#1a212b";   # selection bg
  base03 = "#6f7885";   # comments
  base04 = "#919aa6";   # dark fg
  base05 = "#c9d1d9";   # default fg
  base06 = "#aeb6bf";   # light fg
  base07 = "#d6d9de";   # lightest fg
  base08 = "#b24b4b";   # blood (keywords, errors)
  base09 = "#c07a5a";   # copper (functions, constants)
  base0A = "#b7aa93";   # gold/sand (classes, search)
  base0B = "#9a5a5a";   # rose (strings)
  base0C = "#7f9fbf";   # sky (regex, support)
  base0D = "#9aa7b5";   # steel (headings, attributes)
  base0E = "#4b5e82";   # oil (imports, storage)
  base0F = "#8b7758";   # ash gold (deprecated, embeds)
}
